            <h3>Adım 2: Unity Tarafında Veriyi İşleme</h3>
            <p>Unity'de sahnede döndürmek istediğiniz nesneye (Küp, Uçak vs.) bu kodu atayın. Veriler doğrudan objenin rotasyonuna yansıyacaktır.</p>
            
            <div class="code-wrapper">
<pre>using UnityEngine;
using System.IO.Ports;

public class HareketKontrol : MonoBehaviour {
    SerialPort port = new SerialPort("COM3", 9600); 
    public float hassasiyet = 2.0f; // Dönüşleri yumuşatmak için hız çarpanı

    void Start() {
        if(!port.IsOpen) port.Open();
        port.ReadTimeout = 50;
    }

    void Update() {
        if (port.IsOpen) {
            try {
                string gelenVeri = port.ReadLine();
                string[] acilar = gelenVeri.Split(',');

                if (acilar.Length == 2) {
                    float pitch = float.Parse(acilar[0]);
                    float roll = float.Parse(acilar[1]);

                    // Hedef açıyı oluştur (Quaternion ile Gimbal Lock problemini önlüyoruz)
                    Quaternion hedefRotasyon = Quaternion.Euler(pitch, 0, roll);

                    // Slerp (Spherical Interpolation) kullanarak dönüşleri pürüzsüzleştir
                    transform.rotation = Quaternion.Slerp(transform.rotation, hedefRotasyon, Time.deltaTime * hassasiyet);
                }
            } 
            catch (System.Exception) { /* Gecikmeleri yoksay */ }
        }
    }

    void OnApplicationQuit() {
        if(port.IsOpen) port.Close();
    }
}</pre>
