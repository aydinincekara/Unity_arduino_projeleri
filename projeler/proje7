            <h3>Adım 1: Arduino Kodunu Yükleme</h3>
            <p>Aşağıdaki kod MPU6050'yi uyandırır, X ve Y eksenlerindeki eğimi (Pitch ve Roll) hesaplayıp aralarında virgül olacak şekilde Unity'ye yollar.</p>
            
            <div class="code-wrapper">
<pre>#include &lt;Wire.h&gt;

const int MPU = 0x68; // MPU6050 I2C adresi
int16_t AcX, AcY, AcZ;
float pitch, roll;

void setup() {
  Wire.begin();
  Wire.beginTransmission(MPU);
  Wire.write(0x6B); // Güç yönetimi register'ı
  Wire.write(0);    // Sensörü uyandır
  Wire.endTransmission(true);
  Serial.begin(9600);
}

void loop() {
  Wire.beginTransmission(MPU);
  Wire.write(0x3B);  // İvme verilerinin başladığı adres
  Wire.endTransmission(false);
  Wire.requestFrom(MPU, 6, true);  // 6 byte veri iste (X, Y, Z için 2'şer byte)

  // Verileri oku
  AcX = Wire.read() &lt;&lt; 8 | Wire.read();  
  AcY = Wire.read() &lt;&lt; 8 | Wire.read();  
  AcZ = Wire.read() &lt;&lt; 8 | Wire.read();  

  // Eğim hesabı (Matematiksel dönüşüm)
  pitch = -(atan2(AcX, sqrt(AcY * AcY + AcZ * AcZ)) * 180.0) / PI;
  roll  = (atan2(AcY, AcZ) * 180.0) / PI;

  // Unity'ye gönder (Format: Pitch,Roll)
  Serial.print(pitch);
  Serial.print(",");
  Serial.println(roll);

  delay(20);
}</pre>
