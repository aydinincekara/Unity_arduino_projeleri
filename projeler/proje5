            <h3>Adım 2: Unity Tarafında Veriyi İşleme</h3>
            <p>Unity'de yeni bir C# betiği oluşturun (adını <code>MesafeKameraKontrol</code> yapabilirsiniz) ve bunu sahnedeki <strong>Main Camera</strong> nesnesine sürükleyin.</p>
            
            <div class="code-wrapper">
<pre>using UnityEngine;
using System.IO.Ports;

public class MesafeKameraKontrol : MonoBehaviour {
    SerialPort port = new SerialPort("COM3", 9600); // Arduino portunuz
    private Camera anaKamera;
    private float hedefZoom;

    void Start() {
        anaKamera = GetComponent&lt;Camera&gt;();
        hedefZoom = anaKamera.fieldOfView; // Başlangıç açısını al
        
        if(!port.IsOpen) port.Open();
        port.ReadTimeout = 50;
    }

    void Update() {
        if (port.IsOpen) {
            try {
                string gelenVeri = port.ReadLine();
                float fizikselMesafe = float.Parse(gelenVeri);

                // Sensörden gelen 5cm ile 50cm arası değeri,
                // Kameranın 20 ile 60 FOV (Zoom) değeri arasına haritala (Mapping)
                hedefZoom = Mathf.Clamp(fizikselMesafe + 20f, 20f, 80f);
            } 
            catch (System.Exception) { /* Veri gecikmesi yoksayılır */ }
        }

        // Mathf.Lerp kullanarak zoom geçişini "Pürüzsüz (Smooth)" hale getiriyoruz
        // Aksi takdirde sensördeki ufak oynamalar kamerayı titretir!
        anaKamera.fieldOfView = Mathf.Lerp(anaKamera.fieldOfView, hedefZoom, Time.deltaTime * 5f);
    }

    void OnApplicationQuit() {
        if(port.IsOpen) port.Close();
    }
}</pre>
