            <h3>Adım 1: Arduino Kodunu Yükleme</h3>
            <p>Aşağıdaki kod Trig pininden sinyal yollar, Echo pininden dinler ve formül ile santimetre (cm) hesabı yaparak sonucu bilgisayara gönderir.</p>
            
            <div class="code-wrapper">
<pre>const int trigPin = 9;
const int echoPin = 10;

long sure;
int mesafe;

void setup() {
  pinMode(trigPin, OUTPUT); // Ses gönderici çıkış
  pinMode(echoPin, INPUT);  // Yankı dinleyici giriş
  Serial.begin(9600);
}

void loop() {
  // Trig pinini temizle ve 10 mikrosaniye boyunca ses dalgası gönder
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Echo pininden dönen dalganın süresini oku
  sure = pulseIn(echoPin, HIGH);

  // Sesin hızına göre (havada yaklaşık 340 m/s) mesafeyi cm'ye çevir
  mesafe = sure * 0.034 / 2;

  // Güvenlik: Sadece anlamlı değerleri (2cm ile 200cm arası) gönder
  if(mesafe > 2 && mesafe < 200) {
    Serial.println(mesafe);
  }

  // Sensörü yormamak için kısa bekleme
  delay(50);
}</pre>
